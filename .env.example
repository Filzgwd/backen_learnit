PORT=5000

# Neon / PostgreSQL connection string (do NOT commit secrets to VCS)
# Replace placeholders with your real values
DATABASE_URL=postgresql://<neon_user>:<neon_password>@<project>.<region>.neon.tech:5432/<database_name>?sslmode=require&channel_binding=require

# Optional local DB fallback (comment out if not used)
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=learn_it
# DB_PASS=your_local_db_password
# DB_PORT=5432

JWT_SECRET=your_jwt_secret_key

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

FRONTEND_URL=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
